{
  "name": "astroprocessor",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --parallel --recursive dev",
    "dev:api": "corepack pnpm --filter @astroprocessor/astrology-core build && corepack pnpm --filter @astroprocessor/api dev",
    "dev:web": "corepack pnpm --filter @astroprocessor/web dev",
    "build": "corepack pnpm --recursive build",
    "typecheck": "corepack pnpm --filter @astroprocessor/astrology-core build && corepack pnpm --recursive typecheck",
    "lint": "corepack pnpm --recursive lint",
    "ephemeris:download": "corepack pnpm --filter @astroprocessor/astrology-core ephemeris:download",
    "smoke:natal": "corepack pnpm --filter @astroprocessor/astrology-core smoke:natal",
    "accuracy:generate": "corepack pnpm --filter @astroprocessor/astrology-core accuracy:generate",
    "accuracy:verify": "corepack pnpm --filter @astroprocessor/astrology-core accuracy:verify",
    "prisma:generate": "corepack pnpm --filter @astroprocessor/api prisma:generate",
    "db:push": "corepack pnpm --filter @astroprocessor/api db:push"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
